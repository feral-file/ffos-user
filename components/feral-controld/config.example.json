{
  "cdp": {
    "endpoint": "localhost"
  },
  "relayer": {
    "endpoint": "wss://example.com/ws",
    "apiKey": "YOUR_RELAYER_API_KEY"
  },
  "mintPairing": {
    "enabled": false,
    "brokerBaseURL": "https://mint-pairing.example.com",
    "idleTTLSeconds": 300,
    "pollIntervalMillis": 500,
    "approvalTimeoutSeconds": 300
  },
  "sentry": {
    "dsn": "https://YOUR_SENTRY_DSN@o0.ingest.sentry.io/0",
    "debug": "false",
    "sample_rate": "1.0",
    "environment": "production",
    "release": "feral-controld@1.0.0",
    "repository": "organization/repository-name"
  },
  "openpanel": {
    "clientId": "YOUR_OPENPANEL_CLIENT_ID",
    "clientSecret": "YOUR_OPENPANEL_CLIENT_SECRET"
  }
}
