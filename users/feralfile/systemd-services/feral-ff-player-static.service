[Unit]
Description=Serve bundled ff-player static files on loopback (dev / local player override)
# Only run when FFOS (or a dev image) ships a static tree for the player. ExecStart still no-ops safely if darkhttpd is missing.
ConditionPathIsDirectory=/opt/feral/ff-player
After=system-ready.target
Before=chromium-kiosk.service

[Service]
Type=simple
Environment="XDG_RUNTIME_DIR=/run/user/1000"
ExecStart=/bin/bash /home/feralfile/scripts/serve-ff-player-static.sh
Restart=on-failure
RestartSec=3
StandardOutput=append:/home/feralfile/.logs/ff-player-static.log
StandardError=append:/home/feralfile/.logs/ff-player-static.log

[Install]
WantedBy=default.target
